# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — Upstash Redis for chatbot rate limiting.
# Sign up at https://upstash.com, create a free Redis DB, paste REST URL + token.
# If unset, rate limiting is disabled (fine for local dev, risky for public prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Path to the cloned UFO-USA repo (relative to pursue-webapp/ or absolute).
UFO_USA_PATH=../UFO-USA
