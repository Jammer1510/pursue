                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              ","page_count":6,"was_truncated":1,"llm_model_metadata":"gemini-2.5-flash","llm_model_bust":"gemini-2.5-flash","ingested_at":"2026-05-11T20:22:48.935Z","metadata_hash":"0ee50b7d8ce38927906fb327ed86ec836660c98b7fe23047da69cd398a642eda","cover_up_score":35,"cover_up_reasoning":"The document exhibits routine redactions consistent with operational security and personal privacy (FOIA exemptions b)(6), 1.4a, 1.4g, b)(1)). While classified as SECRET, it has been declassified ahead of its original schedule and approved for release to AARO, indicating a process of transparency rather than active concealment. There is no evidence of classified annexes being withheld or contradictions with public statements.","title_zh":null,"summary_zh":null,"reported_object_description_zh":null,"reported_behavior_zh":null,"official_resolution_zh":null,"bust_reasoning_zh":null,"cover_up_reasoning_zh":null,"incident_location_zh":null,"claims":["UAP observed during a PGM shot","UAP appeared as a lens flare on MX-20 and MX-25 IR sensors","UAP moved at a high rate of speed","Flare was associated with a significant heat source"],"claims_zh":["","","",""],"sensors":["Countermeasures Dispenser","Electronic Countermeasures","GPS/SADL","IR sensor","Infrared Countermeasures","Missile Warning System","Radar","Radar Warning Receiver"],"witnesses":["[redacted]'S CREW"],"bust_explanations":["The document's metadata explicitly lists 'lens flare' as one of the object descriptions for the UAP. This is a strong indicator that a mundane optical artifact was considered or identified.","The UAP was observed 'DURING ITS PGM SHOT' (Precision Guided Munition shot). This context strongly suggests the observation could be related to the munition itself, its impact, target debris, or a sensor artifact caused by the event (e.g., heat, light, or debris from the explosion).","The narrative is extremely brief, stating only that the crew 'OBSERVED AN UNIDENTIFIED AERIAL PHENOMENA' with a 'significant heat source' moving at a 'high rate of speed'. It lacks specific kinematics, shape, or explicit confirmation of multi-sensor detection (e.g., radar *and* IR detection of the UAP itself, beyond just listing the aircraft's equipment), which would resist mundane explanations."],"bust_explanations_zh":["","",""],"cover_up_indicators":["Routine redaction of names, phone numbers, and emails (FOIA Exemption b)(6))","Redaction of operational details (unit, callsign, specific locations, aircraft tail numbers) for OPSEC (FOIA Exemption 1.4a, 1.4g, b)(1))"],"cover_up_indicators_zh":["",""],"tags":[{"category":"behavior","tag":"high-speed"},{"category":"behavior","tag":"moving-through-field-of-view"},{"category":"object","tag":"heat-source"},{"category":"object","tag":"lens-flare"},{"category":"object","tag":"uap"},{"category":"theme","tag":"ir-sensor"},{"category":"theme","tag":"military-engagement"},{"category":"theme","tag":"multi-sensor"},{"category":"theme","tag":"weapons-calibration"}],"locations":[{"id":848,"event_id":528,"position":0,"location_text":"Iraq","latitude":null,"longitude":null,"geocode_source":null,"kind":"unknown"}]}
